# Luna Mobile API — variáveis locais (opcional)
# Copia para .env na raiz luna-core ou exporta antes de `npm run start`

# LUNA_MOBILE_API_PORT=7742

# Firebase Admin — persistência Firestore (mesmo projecto luna-8787d)
# Opção A: JSON inline (Railway)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Opção B: caminho local (dev)
# FIREBASE_SERVICE_ACCOUNT_PATH=../../../orbit-legacy/chaves/luna-8787d-firebase-adminsdk-fbsvc-3ad86e7145.json

# Exige Bearer token quando Admin está configurado (default: true)
# LUNA_FIREBASE_AUTH_REQUIRED=true

# STT — usa LUNA_API_KEY (Groq) por defeito
# LUNA_STT_MODEL=whisper-large-v3-turbo
# LUNA_STT_PROMPT=Mensagem de voz em português do Brasil.

# ── Provedores LLM (pelo menos um) ─────────────────────────────────────────
# Groq (principal)
# LUNA_API_KEY=gsk_...
# LUNA_API_BASE=https://api.groq.com/openai/v1
# LUNA_MODELO_MENOR=llama-3.1-8b-instant
# LUNA_MODELO_MAIOR=openai/gpt-oss-120b

# OpenRouter (modelos free com tool calling — mobile escolhe em Ajustes)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL_CHAT=mistralai/mistral-small-3.1-24b-instruct:free
# OPENROUTER_MODEL_CODE=qwen/qwen3-coder:free
# OPENROUTER_HTTP_REFERER=https://github.com/NowardEthan/luna-core
# OPENROUTER_APP_TITLE=Luna Orbit Mobile
#
# Lista completa Railway: ../env.profiles/railway.env.example
