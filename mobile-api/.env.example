# Luna Mobile API — variáveis locais (opcional)
# Lista completa Railway: ../env.profiles/RAILWAY-VARIAVEIS.md

# LUNA_MOBILE_API_PORT=7742

# ── Cerebras (GLM 4.7 — chat principal) ────────────────────────────────────
# CEREBRAS_API_KEY=csk_...
# CEREBRAS_API_BASE=https://api.cerebras.ai/v1
# CEREBRAS_MODEL=zai-glm-4.7
# CEREBRAS_TEMPERATURA=1
# CEREBRAS_REASONING_EFFORT=medium
# LUNA_STREAM_ENABLED=1

# ── Groq (só STT + visão) ────────────────────────────────────────────────
# LUNA_API_KEY=gsk_...
# LUNA_STT_API_KEY=gsk_...
# LUNA_VISION_API_KEY=gsk_...
# LUNA_API_BASE=https://api.groq.com/openai/v1
# LUNA_STT_MODEL=whisper-large-v3-turbo

# ── Firebase Admin ─────────────────────────────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# LUNA_FIREBASE_AUTH_REQUIRED=true
# LUNA_STORE=firestore
# LUNA_CRIADOR_UID=

# ── Asaas ──────────────────────────────────────────────────────────────────
# ASAAS_ENV=production
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=

# ── Pesquisa web (Tavily) ─────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...
# WEB_SEARCH_PROVIDER=tavily
# TAVILY_SEARCH_DAYS=30
# LUNA_AGENTIC_WEB_SEARCH=1
