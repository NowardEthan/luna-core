# URL da Luna Mobile API
# Local: http://localhost:7742
# Railway: https://<servico>.up.railway.app
# Android emulador (API local): http://10.0.2.2:7742
EXPO_PUBLIC_LUNA_API_URL=http://localhost:7742

# STT — lê LUNA_API_KEY de core/src/luna-core/.env (Groq)
# EXPO_PUBLIC_STT_LANGUAGE=pt
#
# Visão — imagens anexadas passam por POST /v1/vision na Luna API (Groq Llama 4 Scout)
# Documentos (PDF, DOCX, MD, TXT, JSON, CSV, HTML, XML, YAML) passam por POST /v1/extract-documents
# Usa a mesma LUNA_API_KEY no Railway; redeploy após actualizar mobile-api.

# Firebase (projecto luna-8787d — mesmo do Orbit desktop)
# Activar Auth anónimo no Firebase Console → Authentication → Sign-in method
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=luna-8787d
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=luna-8787d.firebaseapp.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=luna-8787d.firebasestorage.app
# Anexos (imagens, PDF, áudio) sobem para Storage em users/{uid}/conversations/...
# Regras: orbit-mobile/storage.rules (mesmo padrão do Orbit legacy)
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Google Sign-In — Firebase luna-8787d (projecto 1068126871324)
# Web Client ID (Firebase Console → Authentication → Google → Web SDK)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=1068126871324-XXXX.apps.googleusercontent.com
#
# Google Cloud + Firebase → app Android com:
#   package: com.luna.orbitmobile
#   SHA-1 debug (keystore android/app/debug.keystore do Expo — NÃO ~/.android):
#   5E:8F:16:06:2E:A3:CD:2C:4A:0D:54:78:76:BA:A6:F3:8C:AB:F6:25
# Verificar: cd android && gradlew :app:signingReport
# Firebase Console → Authentication → Sign-in method → Google (activar)
#
# Google Cloud — cliente WEB (só URLs http/https; NÃO uses orbit-mobile:// aqui):
#   https://luna-8787d.firebaseapp.com/__/auth/handler
#
# Google Cloud — credencial ANDROID (Create credentials → OAuth → Android):
#   Package: com.luna.orbitmobile
#   SHA-1 debug: keytool -list -v -keystore %USERPROFILE%\.android\debug.keystore -alias androiddebugkey -storepass android -keypass android
#   Copia o Android Client ID para EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID acima.
# OAuth no telemóvel requer development build (npx expo run:android), não Expo Go.

# ── Railway (Variables no dashboard, não commitar) ─────────────────────────
# LUNA_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-v1-...
# Ver: core/src/luna-core/env.profiles/railway.env.example
