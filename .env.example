# Luna Core — copie para .env ou use: npm run luna-env:local / luna-env:cloud (no Orbit)
#
# Perfis prontos em env.profiles/
#   local.env       → LM Studio (não consome cota cloud)
#   cloud-groq.env  → Groq (consome cota P3)

# ── Perfil LOCAL (activo por defeito nos perfis) ───────────────────────────
LUNA_API_KEY=lm-studio
LUNA_API_BASE=http://localhost:1234/v1
LUNA_MODELO_MENOR=qwen/qwen2.5-vl-7b
LUNA_MODELO_MAIOR=qwen/qwen2.5-vl-7b
LUNA_TEMPERATURA_MAIOR=0.85
LUNA_API_PAUSA_MS=300

# LM Studio: Local Server porta 1234. GGUF só no disco — Core usa a API.
# LUNA_JSON_ESTRITO=1  # forçar json_object (só se o modelo suportar)

# ── Perfil CLOUD (Groq) — ver env.profiles/cloud-groq.env ─────────────────
# LUNA_API_KEY=gsk_...
# LUNA_API_BASE=https://api.groq.com/openai/v1
# LUNA_MODELO_MENOR=llama-3.1-8b-instant
# LUNA_MODELO_MAIOR=openai/gpt-oss-120b
# LUNA_API_PAUSA_MS=2500

# ── OpenRouter (opcional, modelo menor separado) ─────────────────────────
# LUNA_API_KEY_MENOR=sk-or-v1-...
# LUNA_API_BASE_MENOR=https://openrouter.ai/api/v1
