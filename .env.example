# Luna Core — Groq (copie para .env se ainda não tiver)
# Keys: https://console.groq.com/keys

LUNA_API_KEY=

LUNA_API_BASE=https://api.groq.com/openai/v1

LUNA_MODELO_MENOR=llama-3.1-8b-instant
# Pausa entre chamadas LLM (ms) — evita rate limit no comparativo A/B
LUNA_API_PAUSA_MS=2500

# Outros provedores (opcional):
# OpenAI:  LUNA_API_BASE=https://api.openai.com/v1
# Ollama:  LUNA_API_BASE=http://localhost:11434/v1  LUNA_API_KEY=ollama
