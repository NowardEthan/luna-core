# Variáveis Railway — Luna Mobile API (github.com/NowardEthan/luna-core)
# Copiar cada linha para: Project → Service → Variables
# Healthcheck: GET /health  |  Porta interna: 7742 (EXPOSE no Dockerfile)

# ── Groq (chat rápido + pipeline auxiliar + STT) ───────────────────────────
LUNA_API_KEY=gsk_...
LUNA_API_BASE=https://api.groq.com/openai/v1
LUNA_MODELO_MENOR=llama-3.1-8b-instant
LUNA_MODELO_MAIOR=openai/gpt-oss-120b
LUNA_TEMPERATURA_MAIOR=0.85
LUNA_API_PAUSA_MS=2500

# ── Cerebras (Z.ai GLM 4.7 — modo Completa) ────────────────────────────────
# Chave: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
CEREBRAS_MODEL=zai-glm-4.7
CEREBRAS_TEMPERATURA=1

# ── Firebase Admin (Firestore sync mobile) ─────────────────────────────────
# Colar JSON completo numa única linha:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
LUNA_FIREBASE_AUTH_REQUIRED=true

# ── Asaas (billing mobile — checkout + webhook) ─────────────────────────────
ASAAS_ENV=production
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# Webhook Asaas → https://SEU-SERVICO.up.railway.app/v1/billing/webhook/asaas
# ASAAS_WEBHOOK_ALLOW_OPEN=0

# ── Opcional ───────────────────────────────────────────────────────────────
# LUNA_STT_MODEL=whisper-large-v3-turbo
# LUNA_STT_PROMPT=Mensagem de voz em português do Brasil.
# LUNA_MOBILE_API_PORT=7742
