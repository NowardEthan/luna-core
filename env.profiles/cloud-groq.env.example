# Perfil: CLOUD — Groq (consome cota mensal P3 quando LUNA_API_BASE não é local)
# Copiar para cloud-groq.env e preencher a chave: https://console.groq.com/keys

LUNA_API_KEY=COLOCA_TUA_GROQ_KEY_AQUI
LUNA_API_BASE=https://api.groq.com/openai/v1
LUNA_MODELO_MENOR=llama-3.1-8b-instant
LUNA_MODELO_MAIOR=openai/gpt-oss-120b
LUNA_TEMPERATURA_MAIOR=0.85
LUNA_API_PAUSA_MS=2500
