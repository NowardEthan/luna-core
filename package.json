{
  "name": "orbit-mobile",
  "version": "2.0.1",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.15.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "^13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start --offline",
    "start:clear": "expo start --offline -c",
    "android": "expo start --offline --android",
    "android:run": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android.ps1",
    "android:apk": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-apk.ps1",
    "android:apk:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-apk.ps1 --debug",
    "android:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-apk.ps1",
    "android:sha1": "cd android && gradlew :app:signingReport",
    "ios": "expo start --offline --ios",
    "web": "expo start --offline --web",
    "luna-api": "npm run start --prefix ../core/src/luna-core/mobile-api",
    "luna-api:dev": "npm run dev --prefix ../core/src/luna-core/mobile-api"
  },
  "private": true,
  "overrides": {
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12"
  }
}
