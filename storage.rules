rules_version = '2';
// Deploy no Firebase Console (Storage → Rules) — projecto luna-8787d.
// Caminho: users/{uid}/conversations/{conversationId}/messages/...
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
